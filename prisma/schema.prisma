generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Rank {
  E
  D
  C
  B
  A
  S
}

enum HunterClass {
  NOVICE       // Recién despertado — sin especialización aún
  FIGHTER      // Guerrero — domina la Fuerza (≥55% STR gain)
  RANGER       // Explorador — domina la Agilidad (≥55% AGI gain)
  MAGE         // Mago — domina la Inteligencia (≥55% INT gain)
  ASSASSIN     // Asesino — AGI extrema + intensidad alta
  BEAST        // Bestia — STR extrema + intensidad máxima
  HEALER       // Sanador — equilibrio perfecto + racha consistente
  SHADOW       // Soberano de las Sombras — AGI+INT combinadas (estilo Sung Jin-Woo)
  MONARCH      // Monarca — dominio absoluto + Rango A o S
  SOVEREIGN    // Monarca Supremo — equilibrio total + nivel máximo
}

enum ActivityCategory {
  STRENGTH
  AGILITY
  INTELLIGENCE
  MIXED
}

enum DungeonStatus {
  OPEN        // Abierta para unirse
  COMPLETED   // Terminada — XP distribuida
  CANCELLED
}

enum ItemType {
  WEAPON
  ARMOR
  ACCESSORY
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id          String      @id           // UUID provisto por Supabase Auth
  email       String      @unique
  name        String
  avatarUrl   String?

  level       Int         @default(1)
  xpTotal     Int         @default(0)
  xpToNext    Int         @default(1000)
  rank        Rank        @default(E)
  hunterClass HunterClass @default(NOVICE)

  strength     Int         @default(10)
  agility      Int         @default(10)
  intelligence Int         @default(10)

  gold         Int         @default(0)

  activities            Activity[]
  createdDungeons       Dungeon[]            @relation("CreatedDungeons")
  dungeonParticipations DungeonParticipant[]
  ownedItems            Item[]               @relation("OwnedItems")

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("users")
}

model Activity {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rawText  String
  title    String
  notes    String?

  category        ActivityCategory @default(MIXED)
  durationMinutes Int              @default(0)
  intensity       Int              @default(5)

  xpGranted        Int @default(0)
  strengthGain     Int @default(0)
  agilityGain      Int @default(0)
  intelligenceGain Int @default(0)
  goldGranted      Int @default(0)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

model Dungeon {
  id          String          @id @default(cuid())
  creatorId   String
  creator     User            @relation("CreatedDungeons", fields: [creatorId], references: [id], onDelete: Cascade)

  title       String
  description String?
  scheduledAt DateTime
  category    ActivityCategory
  xpBonus     Int             @default(1000)
  maxParticipants Int         @default(10)
  status      DungeonStatus   @default(OPEN)

  participants DungeonParticipant[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@map("dungeons")
}

// ─────────────────────────────────────────────
// ITEMS — Economía de escasez absoluta
// ─────────────────────────────────────────────

model Item {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  lore        String?
  rank        Rank
  itemType    ItemType
  price       Int      // precio en Oro

  // Efectos sobre XP (multiplicadores, e.g. 0.10 = +10%)
  xpMultiplierStr  Float @default(0)
  xpMultiplierAgi  Float @default(0)
  xpMultiplierInt  Float @default(0)
  xpMultiplierAll  Float @default(0)

  // Efectos sobre estadísticas base (puntos fijos sumados al perfil)
  strengthBonus    Int   @default(0)
  agilityBonus     Int   @default(0)
  intelligenceBonus Int  @default(0)

  // Escasez — null = disponible en tienda
  ownerId  String?
  owner    User?   @relation("OwnedItems", fields: [ownerId], references: [id], onDelete: SetNull)
  equipped Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([rank])
  @@map("items")
}

model DungeonParticipant {
  id          String   @id @default(cuid())
  dungeonId   String
  dungeon     Dungeon  @relation(fields: [dungeonId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt    DateTime @default(now())
  xpReceived  Int      @default(0)

  @@unique([dungeonId, userId])
  @@index([userId])
  @@map("dungeon_participants")
}
